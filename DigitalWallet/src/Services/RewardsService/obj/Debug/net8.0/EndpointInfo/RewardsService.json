{
  "openapi": "3.0.1",
  "info": {
    "title": "Rewards Service API",
    "version": "v1"
  },
  "paths": {
    "/api/rewards/account": {
      "get": {
        "tags": [
          "Rewards"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/rewards/transactions": {
      "get": {
        "tags": [
          "Rewards"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/rewards/catalog": {
      "get": {
        "tags": [
          "Rewards"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/rewards/redeem": {
      "post": {
        "tags": [
          "Rewards"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RedeemRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RedeemRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RedeemRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/rewards/redemptions": {
      "get": {
        "tags": [
          "Rewards"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RedeemRequestDto": {
        "type": "object",
        "properties": {
          "catalogItemId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter JWT Bearer token",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}