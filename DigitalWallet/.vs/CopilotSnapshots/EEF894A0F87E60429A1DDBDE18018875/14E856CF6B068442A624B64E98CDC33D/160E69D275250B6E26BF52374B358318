using AuthService.Application.Interfaces.Repositories;
using AuthService.Domain.Entities;
using AuthService.Infrastructure.Data;
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.Caching.Memory;

namespace AuthService.Infrastructure.Repositories;

public class OTPRepository : IOTPRepository
{
    private readonly IMemoryCache _cache;
    private readonly AuthDbContext _db;

    public OTPRepository(IMemoryCache cache, AuthDbContext db)
    {
        _cache = cache;
        _db = db;
    }

    public Task AddAsync(OTPLog log)
    {
        var options = new MemoryCacheEntryOptions().SetAbsoluteExpiration(log.ExpiresAt);
        _cache.Set($"OTP:{log.UserId}:{log.Code}", log, options);
        _db.OTPLogs.Add(log);
        return Task.CompletedTask;
    }

    public async Task<OTPLog?> FindValidAsync(Guid userId, string code)
    {
        if (_cache.TryGetValue($"OTP:{userId}:{code}", out OTPLog? log) && log != null)
        {
            if (log.UsedAt == null && log.ExpiresAt > DateTime.UtcNow)
                return log;
            return null;
        }

        // Cache miss — fall back to database
        var dbLog = await _db.OTPLogs
            .Where(o => o.UserId == userId && o.Code == code && o.UsedAt == null && o.ExpiresAt > DateTime.UtcNow)
            .OrderByDescending(o => o.ExpiresAt)
            .FirstOrDefaultAsync();

        if (dbLog != null)
        {
            var options = new MemoryCacheEntryOptions().SetAbsoluteExpiration(dbLog.ExpiresAt);
            _cache.Set($"OTP:{userId}:{code}", dbLog, options);
        }

        return dbLog;
    }

    public async Task SaveAsync() => await _db.SaveChangesAsync();
}
